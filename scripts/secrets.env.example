# Spoke secrets — machine-local.
#
# COPY this file to ~/.config/spoke/secrets.env and populate each value
# from your offline source of truth. NEVER commit the populated file.
#
#   mkdir -p ~/.config/spoke
#   cp scripts/secrets.env.example ~/.config/spoke/secrets.env
#   chmod 600 ~/.config/spoke/secrets.env
#   # then edit ~/.config/spoke/secrets.env and fill in the values below
#
# The file is sourced by scripts/launch-main.sh before per-worktree
# .spoke-smoke-env, so worktree-specific overrides still win over these
# machine-wide defaults.
#
# The central registry for spoke secrets (locations, provenance,
# rotation log — never values) lives in
# ~/dev/epistaxis/system/secrets.md.

# ── Required ────────────────────────────────────────────────────

# Gemini Generative Language / Live API key for cloud command, cloud
# TTS, and Gemini Live mode. Lives under the _INACTIVE alias so the
# Gemini CLI does not see it and stays on the active subscription
# login. spoke/__main__.py::_gemini_api_key_env() honors this alias
# before the vanilla GEMINI_API_KEY env var.
#
# Obtain at: https://aistudio.google.com
export GEMINI_API_KEY_INACTIVE=

# ── Optional ────────────────────────────────────────────────────

# OpenRouter cloud assistant backend. Only needed if you select
# OpenRouter in the Assistant Backend menu.
# Obtain at: https://openrouter.ai
# export OPENROUTER_API_KEY=

# Brave Search API key for the bounded public web-search affordance in
# the operator shell. spoke honors SPOKE_BRAVE_SEARCH_API_KEY first and
# then BRAVE_SEARCH_API_KEY; using the provider-native env name here
# keeps the same secret usable across shells and local tools.
# Obtain at: https://brave.com/search/api
# export BRAVE_SEARCH_API_KEY=

# Picovoice Porcupine wake-word detection (hands-free mode).
# As of 2026-04-10 this key is still committed to .spoke-smoke-env in
# the spoke repo. When that migration completes, the key should move
# here and be removed from .spoke-smoke-env.
# Obtain at: https://console.picovoice.ai
# export SPOKE_PICOVOICE_PORCUPINE_ACCESS_KEY=
